# BrushFlow 环境变量配置文件示例

# --- 后端配置 (需以 BF_ 开头) ---
BF_APP_NAME=BrushFlow
BF_DEBUG=false
BF_HOST=0.0.0.0
BF_PORT=8000

# 数据库路径 (可选)
# BF_DB_PATH=./data/brush_flow.db

# 并发与限速默认值 (可在后台页面修改)
BF_DEFAULT_CONCURRENCY=5
BF_GLOBAL_MAX_CONCURRENCY=50
BF_FLUSH_INTERVAL=5

# --- 前端配置 ---
# 前端服务监听端口
VITE_PORT=3000
# 前端代理请求的后端地址 (开发模式下生效)
VITE_BACKEND_URL=http://127.0.0.1:8000
